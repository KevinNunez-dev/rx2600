      <a href="${c.website}" target="_blank" rel="noopener noreferrer" class="cl-action-btn cl-action-ghost">Visit Site</a>
    `;
  }

  function renderList(items) {
    list.innerHTML = '';
    if (!items.length) {
      empty.style.display = 'block';
      count.textContent = '0 locations';
      return;
    }
    empty.style.display = 'none';
    count.textContent = items.length + ' location' + (items.length !== 1 ? 's' : '');

    items.forEach((c, i) => {
      const realIdx = clinics.indexOf(c);
      const card = document.createElement('div');
      card.className = 'cl-card' + (realIdx === activeIdx ? ' active' : '');
      card.setAttribute('role', 'listitem');
      card.setAttribute('tabindex', '0');
      card.setAttribute('aria-label', c.name + ', ' + c.city + ', ' + c.state);
      card.innerHTML = `
        <div class="cl-card-name">${c.name}</div>
        <div class="cl-card-addr">${c.addr}<br>${c.city}, ${c.state} ${c.zip}</div>
        <div class="cl-card-meta">
          <span class="cl-state-tag">${c.state}</span>
          <a href="tel:${c.phone.replace(/[^\d]/g,'')}" class="cl-card-phone" onclick="event.stopPropagation()">${c.phone}</a>
          <a href="${c.website}" target="_blank" rel="noopener noreferrer" class="cl-card-link" onclick="event.stopPropagation()">Website &rarr;</a>
        </div>
      `;
      card.addEventListener('click', () => selectClinic(realIdx));
      card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') selectClinic(realIdx); });
      list.appendChild(card);
    });
  }

  // Init
  renderList(clinics);
  selectClinic(0);

  // Search
  search.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    if (!q) { renderList(clinics); return; }
    const filtered = clinics.filter(c =>
      c.name.toLowerCase().includes(q) ||
      c.city.toLowerCase().includes(q) ||
      c.state.toLowerCase().includes(q) ||
      c.addr.toLowerCase().includes(q)
    );
    renderList(filtered);
  });

  // Scroll reveals (this page uses IntersectionObserver since it's non-panel)
  const revEls = document.querySelectorAll('[data-reveal]');
  if (revEls.length) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const delay = parseInt(e.target.dataset.delay || 0);
        setTimeout(() => e.target.classList.add('revealed'), delay);
        io.unobserve(e.target);
      });
    }, { threshold: 0.15 });
    revEls.forEach(el => io.observe(el));
  }
})();
</script>

</Base>
