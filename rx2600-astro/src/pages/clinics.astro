  const list    = document.getElementById('cl-list');
  const empty   = document.getElementById('cl-empty');
  const count   = document.getElementById('cl-count');
  const search  = document.getElementById('cl-search-input');
  const iframe  = document.getElementById('cl-map-iframe');
  const infoName= document.getElementById('cl-info-name');
  const infoAddr= document.getElementById('cl-info-addr');
  const infoAct = document.getElementById('cl-info-actions');

  let activeIdx = -1;

  function selectClinic(idx) {
    activeIdx = idx;
    const c = clinics[idx];

    // update active card
    document.querySelectorAll('.cl-card').forEach((card, i) => {
      card.classList.toggle('active', i === idx);
    });

    // update map
    iframe.src = c.mapEmbed;

    // update info panel
    infoName.textContent = c.name;
    infoAddr.textContent = c.addr + ', ' + c.city + ', ' + c.state + ' ' + c.zip;
    infoAct.innerHTML = `
      <a href="https://www.google.com/maps/search/?api=1&query=${c.mapQ}" target="_blank" rel="noopener noreferrer" class="cl-action-btn cl-action-primary">Get Directions</a>
