---
import Base from '../layouts/Base.astro';
---
<Base title="Find a Clinic — RX2600" description="Locate an authorized RX2600 clinic near you. Nationwide network of precision robotic therapy providers.">

<style>
  /* ── PAGE SHELL ── */
  .cl-page {
    min-height: 100vh;
    background: #000;
    padding-top: 90px;
    padding-bottom: 5rem;
    cursor: auto;
    overflow-y: auto;
  }

  /* ── HERO HEADER ── */
  .cl-hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }
  .cl-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 30% 60%, rgba(196,24,122,.13) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(123,31,162,.10) 0%, transparent 70%);
    pointer-events: none;
  }
  .cl-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: .65rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(196,24,122,.8);
    margin-bottom: 1rem;
  }
  .cl-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    color: #e8e8f0;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .cl-title span {
    background: linear-gradient(135deg, #c4187a, #9c27b0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cl-subtitle {
    font-size: 1rem;
    color: rgba(232,232,240,.45);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── SEARCH BAR ── */
  .cl-search-wrap {
    max-width: 560px;
    margin: 2rem auto 0;
    position: relative;
  }
  .cl-search {
    width: 100%;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(196,24,122,.25);
    border-radius: 4px;
    padding: .85rem 3rem .85rem 1.25rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: .9rem;
    color: #e8e8f0;
    outline: none;
    transition: border-color .3s, box-shadow .3s;
  }
  .cl-search::placeholder { color: rgba(232,232,240,.28); }
  .cl-search:focus {
    border-color: rgba(196,24,122,.6);
    box-shadow: 0 0 18px rgba(196,24,122,.12);
  }
  .cl-search-icon {
    position: absolute;
    right: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(196,24,122,.55);
    pointer-events: none;
  }

  /* ── MAIN LAYOUT ── */
  .cl-body {
    max-width: 1280px;
    margin: 2.5rem auto 0;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .cl-body { grid-template-columns: 1fr; }
  }

  /* ── CLINIC LIST ── */
  .cl-list-col {
    display: flex;
    flex-direction: column;
    gap: .75rem;
    max-height: 72vh;
    overflow-y: auto;
    padding-right: .5rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(196,24,122,.3) transparent;
  }
  .cl-list-col::-webkit-scrollbar { width: 4px; }
  .cl-list-col::-webkit-scrollbar-track { background: transparent; }
  .cl-list-col::-webkit-scrollbar-thumb { background: rgba(196,24,122,.3); border-radius: 2px; }

  /* ── CLINIC CARD ── */
  .cl-card {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    transition: border-color .25s, background .25s, box-shadow .25s, transform .2s;
    position: relative;
    overflow: hidden;
  }
  .cl-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: linear-gradient(180deg, #c4187a, #7b1fa2);
    transition: width .25s;
    border-radius: 6px 0 0 6px;
  }
  .cl-card:hover,
  .cl-card.active {
    border-color: rgba(196,24,122,.45);
    background: rgba(196,24,122,.06);
    box-shadow: 0 4px 24px rgba(196,24,122,.12);
    transform: translateX(3px);
  }
  .cl-card.active::before { width: 3px; }
  .cl-card-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    color: #e8e8f0;
    margin-bottom: .3rem;
  }
  .cl-card-addr {
    font-size: .78rem;
    color: rgba(232,232,240,.45);
    line-height: 1.5;
    margin-bottom: .55rem;
  }
  .cl-card-meta {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .cl-card-phone {
    font-family: 'Space Mono', monospace;
    font-size: .7rem;
    color: rgba(232,232,240,.4);
    transition: color .2s;
  }
  .cl-card-phone:hover { color: rgba(196,24,122,.9); }
  .cl-card-link {
    font-size: .68rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: rgba(196,24,122,.65);
    border: 1px solid rgba(196,24,122,.22);
    padding: .2rem .55rem;
    border-radius: 2px;
    transition: color .2s, border-color .2s, background .2s;
  }
  .cl-card-link:hover {
    color: #e8e8f0;
    border-color: rgba(196,24,122,.6);
    background: rgba(196,24,122,.1);
  }
  .cl-badge {
    font-size: .6rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(196,24,122,.55);
    background: rgba(196,24,122,.08);
    border: 1px solid rgba(196,24,122,.15);
    padding: .15rem .5rem;
    border-radius: 2px;
  }
  .cl-state-tag {
    font-family: 'Space Mono', monospace;
    font-size: .6rem;
    color: rgba(232,232,240,.25);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── MAP COLUMN ── */
  .cl-map-col {
    position: sticky;
    top: 1.5rem;
  }
  @media (max-width: 900px) {
    .cl-map-col { position: static; }
    .cl-list-col { max-height: none; }
  }
  .cl-map-frame {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.07);
    background: rgba(10,10,14,1);
    position: relative;
  }
  .cl-map-hud {
    position: absolute;
    top: 1rem; left: 1rem;
    background: rgba(0,0,0,.82);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(196,24,122,.25);
    border-radius: 4px;
    padding: .45rem .9rem;
    font-family: 'Space Mono', monospace;
    font-size: .62rem;
    color: rgba(196,24,122,.8);
    letter-spacing: 2px;
    text-transform: uppercase;
    z-index: 2;
    pointer-events: none;
  }
  .cl-map-frame iframe {
    width: 100%;
    height: 68vh;
    min-height: 400px;
    border: none;
    display: block;
    filter: invert(1) hue-rotate(180deg) saturate(0.7) brightness(0.85);
  }
  .cl-map-info {
    background: rgba(5,5,8,.95);
    border-top: 1px solid rgba(196,24,122,.15);
    padding: 1rem 1.25rem;
  }
  .cl-map-info-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: .95rem;
    font-weight: 600;
    color: #e8e8f0;
    margin-bottom: .25rem;
  }
  .cl-map-info-addr {
    font-size: .8rem;
    color: rgba(232,232,240,.4);
    margin-bottom: .65rem;
    line-height: 1.5;
  }
  .cl-map-info-actions {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
  }
  .cl-action-btn {
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: .45rem 1rem;
    border-radius: 2px;
    transition: all .25s;
    cursor: pointer;
  }
  .cl-action-primary {
    background: linear-gradient(135deg, #c4187a, #7b1fa2);
    color: #fff;
    border: 1px solid transparent;
  }
  .cl-action-primary:hover {
    filter: brightness(1.15);
    box-shadow: 0 4px 20px rgba(196,24,122,.35);
  }
  .cl-action-ghost {
    background: transparent;
    color: rgba(232,232,240,.55);
    border: 1px solid rgba(255,255,255,.12);
  }
  .cl-action-ghost:hover {
    color: #e8e8f0;
    border-color: rgba(255,255,255,.3);
  }

  /* ── STATS BAR ── */
  .cl-stats {
    max-width: 1280px;
    margin: 3rem auto 0;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.05);
    border-radius: 6px;
    overflow: hidden;
  }
  @media (max-width: 640px) { .cl-stats { grid-template-columns: 1fr; } }
  .cl-stat {
    background: rgba(0,0,0,.6);
    padding: 1.5rem 2rem;
    text-align: center;
  }
  .cl-stat-num {
    font-family: 'Space Mono', monospace;
    font-size: 1.8rem;
    font-weight: 700;
    background: linear-gradient(135deg, #c4187a, #9c27b0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
  }
  .cl-stat-label {
    font-size: .72rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(232,232,240,.35);
    margin-top: .3rem;
    display: block;
  }

  /* ── NO RESULTS ── */
  .cl-empty {
    display: none;
    text-align: center;
    padding: 3rem 1rem;
    color: rgba(232,232,240,.3);
    font-size: .85rem;
    letter-spacing: 1px;
  }
  .cl-empty svg {
    display: block;
    margin: 0 auto 1rem;
    opacity: .25;
  }

  /* ── COUNT PILL ── */
  .cl-count {
    font-family: 'Space Mono', monospace;
    font-size: .65rem;
    letter-spacing: 1px;
    color: rgba(232,232,240,.35);
    margin-bottom: .75rem;
    padding-left: .1rem;
  }

  /* override body cursor for this page */
  .cl-page, .cl-page * { cursor: auto !important; }
  .cl-page a, .cl-page button { cursor: pointer !important; }
</style>

<div class="cl-page" id="clinics-page">

  <!-- HERO -->
  <section class="cl-hero">
    <p class="cl-eyebrow" data-reveal="up" data-delay="0">Authorized Network</p>
    <h1 class="cl-title" data-reveal="up" data-delay="100">
      Find a <span>RX2600</span> Clinic
    </h1>
    <p class="cl-subtitle" data-reveal="up" data-delay="200">
      Experience next-generation robotic precision therapy at a certified provider near you.
    </p>
    <div class="cl-search-wrap" data-reveal="up" data-delay="300">
      <input
        class="cl-search"
        type="search"
        id="cl-search-input"
        placeholder="Search by city, state, or clinic name…"
        autocomplete="off"
        aria-label="Search clinics"
      />
      <svg class="cl-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
    </div>
  </section>

  <!-- STATS -->
  <div class="cl-stats" data-reveal="up" data-delay="200">
    <div class="cl-stat">
      <span class="cl-stat-num">16</span>
      <span class="cl-stat-label">Certified Clinics</span>
    </div>
    <div class="cl-stat">
      <span class="cl-stat-num">5</span>
      <span class="cl-stat-label">States & Growing</span>
    </div>
    <div class="cl-stat">
      <span class="cl-stat-num">15+</span>
      <span class="cl-stat-label">Years of R&D</span>
    </div>
  </div>

  <!-- BODY: LIST + MAP -->
  <div class="cl-body">

    <!-- LIST -->
    <div>
      <p class="cl-count" id="cl-count">16 locations</p>
      <div class="cl-list-col" id="cl-list" role="list"></div>
      <div class="cl-empty" id="cl-empty" aria-live="polite">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        No clinics match your search.
      </div>
    </div>

    <!-- MAP -->
    <div class="cl-map-col">
      <div class="cl-map-frame">
        <div class="cl-map-hud">// Live Network Map</div>
        <iframe
          id="cl-map-iframe"
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d2899011.3!2d-84.0!3d42.5!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDMwJzAwLjAiTiA4NMKwMDAnMDAuMCJX!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="RX2600 Clinic Network Map"
        ></iframe>
        <div class="cl-map-info" id="cl-map-info">
          <p class="cl-map-info-name" id="cl-info-name">Select a clinic to view details</p>
          <p class="cl-map-info-addr" id="cl-info-addr">Click any location card on the left to focus the map and see contact options.</p>
          <div class="cl-map-info-actions" id="cl-info-actions"></div>
        </div>
      </div>
    </div>

  </div>

</div>

