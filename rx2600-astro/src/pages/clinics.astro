      center: [39.5, -90],
      zoom: 5,
      zoomControl: true,
      scrollWheelZoom: false
    });

    /* Dark map tiles via CartoDB Dark Matter */
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OSM</a> &copy; <a href="https://carto.com/" target="_blank">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19
    }).addTo(map);

    /* ── BUILD CARDS + MARKERS ── */
    var ul = document.getElementById('cards-ul');
    var markers = [];
    var cards = [];

    CLINICS.forEach(function(c, i) {

      /* Card */
      var li = document.createElement('li');
      li.className = 'clinic-card';
      li.dataset.index = i;
      li.dataset.state = c.state;
      li.dataset.search = (c.name + ' ' + c.city + ' ' + c.state + ' ' + c.zip).toLowerCase();
      li.innerHTML =
        '<p class="cc-name">' + c.name + '</p>' +
        '<p class="cc-addr">' + c.addr + '<br>' + c.city + ', ' + c.state + ' ' + c.zip + '</p>' +
        '<div class="cc-meta">' +
          '<a href="tel:' + c.phoneRaw + '" class="cc-phone" onclick="event.stopPropagation()">' + c.phone + '</a>' +
          '<a href="' + c.webUrl + '" target="_blank" rel="noopener noreferrer" class="cc-web" onclick="event.stopPropagation()">' + c.web + '</a>' +
          '<span class="cc-tag">' + c.state + '</span>' +
        '</div>';
      ul.appendChild(li);
      cards.push(li);

      /* Marker */
      var marker = L.marker([c.lat, c.lng], { icon: makeIcon(false) });

      var popupHtml =
        '<div style="font-family:\'Space Grotesk\',sans-serif;">' +
          '<p style="font-weight:700;font-size:.9rem;color:#fff;margin-bottom:.35rem;">' + c.name + '</p>' +
          '<p style="font-size:.75rem;color:rgba(232,232,240,.45);line-height:1.55;margin-bottom:.65rem;">' + c.addr + '<br>' + c.city + ', ' + c.state + ' ' + c.zip + '</p>' +
          '<div style="display:flex;gap:.6rem;flex-wrap:wrap;align-items:center;">' +
            '<a href="tel:' + c.phoneRaw + '" style="font-family:\'Space Mono\',monospace;font-size:.68rem;color:rgba(224,64,251,.8);">' + c.phone + '</a>' +
            '<a href="' + c.mapsUrl + '" target="_blank" rel="noopener noreferrer" style="font-size:.68rem;color:rgba(232,232,240,.35);">Get Directions ↗</a>' +
          '</div>' +
        '</div>';

      marker.bindPopup(popupHtml, { maxWidth: 260 });
      marker.addTo(map);
      markers.push(marker);

      /* Click: card → fly to marker */
      li.addEventListener('click', function() {
        selectClinic(i);
      });

      /* Click: marker → activate card */
      marker.on('click', function() {
        selectClinic(i, false);
      });
    });

    /* ── SELECT CLINIC ── */
    var activeIdx = -1;
    function selectClinic(i, flyToMarker) {
      flyToMarker = flyToMarker !== false;

      /* Deactivate previous */
      if (activeIdx >= 0) {
        cards[activeIdx].classList.remove('active');
        markers[activeIdx].setIcon(makeIcon(false));
        markers[activeIdx].closePopup();
      }

      activeIdx = i;
      cards[i].classList.add('active');
      markers[i].setIcon(makeIcon(true));
      markers[i].openPopup();

      /* Scroll card into view */
      cards[i].scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      /* Fly map */
      if (flyToMarker) {
        map.flyTo([CLINICS[i].lat, CLINICS[i].lng], 13, { duration: 1.2 });
      }
    }

    /* ── SEARCH + FILTER ── */
    var searchInput = document.getElementById('clinic-search');
    var stateSelect = document.getElementById('state-filter');
    var visibleCount = document.getElementById('visible-count');
    var mapCount = document.getElementById('map-count');

    function filterClinics() {
      var q = searchInput.value.toLowerCase().trim();
      var st = stateSelect.value;
      var visible = 0;

      CLINICS.forEach(function(c, i) {
        var matchSearch = !q || cards[i].dataset.search.indexOf(q) !== -1;
        var matchState = !st || c.state === st;
        var show = matchSearch && matchState;

        cards[i].classList.toggle('hidden', !show);

        if (show) {
          visible++;
          markers[i].addTo(map);
        } else {
          markers[i].remove();
        }
      });

      visibleCount.textContent = visible;
      mapCount.textContent = visible + ' Location' + (visible !== 1 ? 's' : '');

      /* Fit map to visible markers */
      var visibleLatLngs = CLINICS
        .filter(function(c, i) { return !cards[i].classList.contains('hidden'); })
        .map(function(c) { return [c.lat, c.lng]; });

      if (visibleLatLngs.length > 1) {
        map.fitBounds(visibleLatLngs, { padding: [40, 40], maxZoom: 12 });
      } else if (visibleLatLngs.length === 1) {
        map.flyTo(visibleLatLngs[0], 13, { duration: 1 });
      }
    }

    searchInput.addEventListener('input', filterClinics);
    stateSelect.addEventListener('change', filterClinics);

    /* Trigger scroll reveals on page load */
    document.querySelectorAll('[data-reveal]').forEach(function(el) {
      var delay = parseInt(el.dataset.delay || 0);
      setTimeout(function() { el.classList.add('revealed'); }, delay + 200);
    });

  }); /* end waitForLeaflet */

})();
</script>
