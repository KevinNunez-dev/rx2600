---
import Base from '../layouts/Base.astro';
---

<Base
  title="Find a Clinic — RX2600"
  description="Locate an RX2600-equipped clinic near you. Browse our nationwide network of certified Robotic Precision Therapy locations."
>

<div class="locator-page">

  <!-- ── PAGE HERO ── -->
  <section class="loc-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="loc-hero-glow" aria-hidden="true"></div>
    <div class="loc-hero-inner">
      <p class="loc-eyebrow" data-reveal="up" data-delay="0">
        <span class="eyebrow-bracket">[</span> Nationwide Network <span class="eyebrow-bracket">]</span>
      </p>
      <h1 class="loc-title" data-reveal="up" data-delay="150">
        Find an RX2600<br/>Clinic Near You.
      </h1>
      <p class="loc-subtitle" data-reveal="up" data-delay="350">
        Every clinic below is certified in Robotic Precision Therapy and equipped with the RX2600 system.
      </p>
      <!-- Search bar -->
      <div class="search-wrap" data-reveal="up" data-delay="500">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input
          type="search"
          id="clinic-search"
          class="search-input"
          placeholder="Search by city, state or clinic name…"
          aria-label="Search clinics"
          autocomplete="off"
        />
        <div class="search-state-wrap">
          <select id="state-filter" class="state-select" aria-label="Filter by state">
            <option value="">All States</option>
            <option value="MI">Michigan</option>
            <option value="FL">Florida</option>
            <option value="AR">Arkansas</option>
          </select>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MAIN CONTENT ── -->
  <div class="loc-body">

    <!-- Left: Clinic List -->
    <aside class="clinic-list" id="clinic-list" aria-label="Clinic list">
      <p class="list-count"><span id="visible-count">16</span> clinics found</p>
      <ul id="cards-ul" role="list"></ul>
    </aside>

    <!-- Right: Map -->
    <div class="map-pane">
      <div id="map" aria-label="Clinic map"></div>
      <div class="map-hud" aria-hidden="true">
        <span class="hud-badge">RX2600 NETWORK</span>
        <span class="hud-count" id="map-count">16 Locations</span>
      </div>
    </div>

  </div>

  <!-- ── FOOTER CTA ── -->
  <section class="loc-cta">
    <div class="loc-cta-grid" aria-hidden="true"></div>
    <div class="loc-cta-inner">
      <p class="cta-eyebrow">[ Not in your area yet? ]</p>
      <h2 class="cta-heading">Bring the RX2600<br/>to Your Clinic.</h2>
      <p class="cta-body">Join the growing nationwide network. Get certified, get equipped, and become the most advanced therapy clinic in your market.</p>
      <div class="cta-actions">
        <a href="https://rx2600.com" target="_blank" rel="noopener noreferrer" class="btn-primary">Request a Demo <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        <a href="tel:8556292805" class="btn-ghost"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.6 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.1 4.2 2 2 0 0 1 5.08 2h3a2 2 0 0 1 2 1.72c.12.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91A16 16 0 0 0 15 15.91l1.27-1.27a2 2 0 0 1 2.11-.45c.9.35 1.85.6 2.81.72A2 2 0 0 1 22 16.92z"/></svg>(855) 629-2805</a>
      </div>
    </div>
  </section>

</div>

</Base>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
/* ── PAGE SHELL ── */
.locator-page {
  background: #000;
  color: #e8e8f0;
  min-height: 100dvh;
  font-family: 'Space Grotesk', system-ui, sans-serif;
  overflow-x: hidden;
  overflow-y: auto;
}

/* ── HERO ── */
.loc-hero {
  position: relative;
  padding: 140px 2rem 5rem;
  overflow: hidden;
}
.loc-hero-glow {
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(196,24,122,.07) 0%, transparent 65%);
}
.hero-grid {
  position: absolute; inset: 0; z-index: 0; pointer-events: none;
  background-image: linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse at 50% 0%, rgba(0,0,0,.5) 0%, transparent 70%);
}
.loc-hero-inner {
  position: relative; z-index: 1;
  max-width: 860px; margin: 0 auto; text-align: center;
}
.loc-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: .68rem; letter-spacing: 3px; text-transform: uppercase;
  color: rgba(232,232,240,.3); margin-bottom: 1.5rem;
}
.eyebrow-bracket { opacity: .3; }
.loc-title {
  font-size: clamp(2.5rem, 6vw, 5rem);
  font-weight: 700; line-height: 1.08; color: #fff;
  margin-bottom: 1.25rem;
}
.loc-subtitle {
  font-size: clamp(.95rem, 1.3vw, 1.05rem);
  color: rgba(232,232,240,.38); line-height: 1.8;
  max-width: 560px; margin: 0 auto 2.5rem;
}

/* ── SEARCH ── */
.search-wrap {
  display: flex; align-items: center; gap: .75rem;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 2px;
  padding: .65rem 1rem;
  max-width: 680px; margin: 0 auto;
  transition: border-color .3s;
}
.search-wrap:focus-within {
  border-color: rgba(224,64,251,.4);
  box-shadow: 0 0 18px rgba(224,64,251,.08);
}
.search-icon { color: rgba(232,232,240,.25); flex-shrink: 0; }
.search-input {
  flex: 1; background: transparent; border: none; outline: none;
  color: #e8e8f0; font-size: .9rem;
  font-family: 'Space Grotesk', sans-serif;
}
.search-input::placeholder { color: rgba(232,232,240,.22); }
.search-state-wrap {
  border-left: 1px solid rgba(255,255,255,.06);
  padding-left: .75rem;
}
.state-select {
  background: transparent; border: none; outline: none;
  color: rgba(232,232,240,.45);
  font-size: .78rem; font-family: 'Space Grotesk', sans-serif;
  letter-spacing: 1px; text-transform: uppercase;
  cursor: pointer; padding-right: .25rem;
}
.state-select option { background: #0d0d10; color: #e8e8f0; }

/* ── MAIN BODY ── */
.loc-body {
  display: grid;
  grid-template-columns: 400px 1fr;
  height: calc(100dvh - 80px);
  max-height: 780px;
  border-top: 1px solid rgba(255,255,255,.05);
}

/* ── CLINIC LIST ── */
.clinic-list {
  overflow-y: auto;
  border-right: 1px solid rgba(255,255,255,.05);
  scroll-behavior: smooth;
}
.clinic-list::-webkit-scrollbar { width: 4px; }
.clinic-list::-webkit-scrollbar-track { background: transparent; }
.clinic-list::-webkit-scrollbar-thumb { background: rgba(196,24,122,.3); border-radius: 2px; }

.list-count {
  padding: 1rem 1.25rem .5rem;
  font-family: 'Space Mono', monospace;
  font-size: .62rem; letter-spacing: 2px; text-transform: uppercase;
  color: rgba(232,232,240,.2);
  border-bottom: 1px solid rgba(255,255,255,.04);
}

#cards-ul { list-style: none; }

.clinic-card {
  padding: 1.1rem 1.25rem;
  border-bottom: 1px solid rgba(255,255,255,.04);
  cursor: pointer;
  transition: background .25s;
  position: relative;
}
.clinic-card::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
  background: transparent;
  transition: background .25s;
}
.clinic-card:hover,
.clinic-card.active {
  background: rgba(196,24,122,.05);
}
.clinic-card.active::before {
  background: linear-gradient(to bottom, #c4187a, #7b1fa2);
}
.clinic-card.hidden { display: none; }

.cc-name {
  font-size: .88rem; font-weight: 600; color: #fff;
  margin-bottom: .35rem; line-height: 1.3;
}
.cc-addr {
  font-size: .75rem; color: rgba(232,232,240,.35);
  line-height: 1.5; margin-bottom: .6rem;
}
.cc-meta {
  display: flex; flex-wrap: wrap; gap: .5rem .75rem;
  align-items: center;
}
.cc-phone {
  font-family: 'Space Mono', monospace;
  font-size: .68rem; color: rgba(224,64,251,.7);
  transition: color .2s;
}
.cc-phone:hover { color: #e040fb; }
.cc-web {
  font-size: .68rem; letter-spacing: .5px;
  color: rgba(232,232,240,.25);
  transition: color .2s;
}
.cc-web:hover { color: rgba(232,232,240,.7); }
.cc-tag {
  font-family: 'Space Mono', monospace;
  font-size: .58rem; letter-spacing: 1.5px; text-transform: uppercase;
  color: rgba(196,24,122,.5);
  background: rgba(196,24,122,.06);
  border: 1px solid rgba(196,24,122,.12);
  padding: .15rem .45rem; border-radius: 2px;
  margin-left: auto;
}

/* ── MAP ── */
.map-pane {
  position: relative;
  background: #060608;
}
#map {
  width: 100%; height: 100%;
  z-index: 1;
}
.map-hud {
  position: absolute; top: 1rem; left: 1rem; z-index: 500;
  display: flex; flex-direction: column; gap: .35rem;
  pointer-events: none;
}
.hud-badge {
  font-family: 'Space Mono', monospace;
  font-size: .6rem; letter-spacing: 2px; text-transform: uppercase;
  color: rgba(232,232,240,.4);
  background: rgba(0,0,0,.8);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.07);
  padding: .3rem .7rem; border-radius: 2px;
}
.hud-count {
  font-family: 'Space Mono', monospace;
  font-size: .6rem; letter-spacing: 1.5px;
  color: rgba(224,64,251,.7);
  background: rgba(0,0,0,.75);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(224,64,251,.15);
  padding: .25rem .65rem; border-radius: 2px;
}

/* ── CTA ── */
.loc-cta {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  padding: 7rem 2rem;
  overflow: hidden;
}
.loc-cta-grid {
  position: absolute; inset: 0;
  background-image: linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
                    linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
  background-size: 60px 60px;
}
.loc-cta-grid::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 50%, rgba(196,24,122,.06) 0%, transparent 65%);
}
.loc-cta-inner {
  position: relative; z-index: 1;
  max-width: 640px; text-align: center;
}
.cta-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: .68rem; letter-spacing: 3px; text-transform: uppercase;
  color: rgba(232,232,240,.22); margin-bottom: 1.5rem;
}
.cta-heading {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700; line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
}
.cta-body {
  font-size: .97rem; line-height: 1.85;
  color: rgba(232,232,240,.38); margin-bottom: 2.5rem;
}
.cta-actions {
  display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;
}

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .loc-body {
    grid-template-columns: 1fr;
    grid-template-rows: auto 380px;
    height: auto;
    max-height: none;
  }
  .clinic-list {
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,.05);
    max-height: 420px;
  }
  .map-pane { height: 380px; }
}
@media (max-width: 600px) {
  .loc-hero { padding: 120px 1.25rem 3.5rem; }
  .search-wrap { flex-wrap: wrap; gap: .5rem; }
  .state-select { border-left: none; padding-left: 0; }
  .loc-title { font-size: clamp(2rem, 9vw, 3rem); }
  .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
  .cta-actions { flex-direction: column; }
}

/* ── Leaflet dark skin overrides ── */
.leaflet-container {
  background: #0d0c10 !important;
  font-family: 'Space Grotesk', sans-serif !important;
}
.leaflet-popup-content-wrapper {
  background: rgba(10,9,14,.97) !important;
  border: 1px solid rgba(255,255,255,.08) !important;
  border-radius: 4px !important;
  box-shadow: 0 8px 32px rgba(0,0,0,.7) !important;
  backdrop-filter: blur(16px);
  color: #e8e8f0 !important;
}
.leaflet-popup-tip { background: rgba(10,9,14,.97) !important; }
.leaflet-popup-content { margin: 14px 18px !important; min-width: 200px; }
.leaflet-popup-close-button { color: rgba(232,232,240,.4) !important; }
.leaflet-popup-close-button:hover { color: #e8e8f0 !important; }
.leaflet-control-zoom a {
  background: rgba(10,9,14,.9) !important;
  border-color: rgba(255,255,255,.08) !important;
  color: rgba(232,232,240,.6) !important;
}
.leaflet-control-zoom a:hover {
  background: rgba(196,24,122,.15) !important;
  color: #fff !important;
}
.leaflet-control-attribution {
  background: rgba(0,0,0,.6) !important;
  color: rgba(232,232,240,.2) !important;
  font-size: 9px !important;
}
.leaflet-control-attribution a { color: rgba(232,232,240,.3) !important; }
</style>

