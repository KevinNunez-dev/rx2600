  /* ── CUSTOM MARKER SVG ── */
  function makeIcon(active) {
    return L.divIcon({
      className: '',
      html: `<svg width="28" height="36" viewBox="0 0 28 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 0C6.268 0 0 6.268 0 14c0 9.523 14 22 14 22s14-12.477 14-22C28 6.268 21.732 0 14 0z"
          fill="${ active ? '#c4187a' : 'rgba(196,24,122,0.5)'}" />
        <circle cx="14" cy="14" r="5" fill="#fff" fill-opacity="${ active ? '1' : '0.7'}" />
      </svg>`,
      iconSize: [28, 36],
      iconAnchor: [14, 36],
      popupAnchor: [0, -38]
    });
  }

  /* ── WAIT FOR LEAFLET ── */
  function waitForLeaflet(cb, tries) {
    tries = tries || 0;
    if (typeof L !== 'undefined') { cb(); return; }
    if (tries > 50) return;
    setTimeout(function() { waitForLeaflet(cb, tries + 1); }, 100);
  }

  waitForLeaflet(function() {

