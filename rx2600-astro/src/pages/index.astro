<script is:inline>
  // Guard: disable custom scroll engine on mobile (<=768px)
  // On mobile, panels are normal block elements with natural scroll
  (function() {
    if (window.innerWidth <= 768) {
      // On mobile: just trigger reveals for all panels immediately
      document.querySelectorAll('[data-reveal]').forEach(function(el) {
        var delay = parseInt(el.dataset.delay || 0);
        setTimeout(function() { el.classList.add('revealed'); }, delay + 100);
      });
      return; // skip the scroll engine entirely
    }
  })();
</script>
