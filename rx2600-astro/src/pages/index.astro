---
import Base from '../layouts/Base.astro';
---
<Base>

  <!-- ─── NAV ─── -->
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="#home" class="nav-logo" aria-label="RX2600 Home">RX2600</a>
    <ul class="nav-links" role="list">
      <li><a href="#product">The System</a></li>
      <li><a href="#technology">Technology</a></li>
      <li><a href="#clinical">Clinical</a></li>
      <li><a href="#clinics">For Clinics</a></li>
    </ul>
    <a href="#contact" class="nav-cta">Request Demo</a>
    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- ─── HERO ─── -->
  <section class="hero" id="home" aria-label="Hero">
    <div class="hero-media">
      <img
        src="https://rx2600.com/wp-content/uploads/2025/02/robot-main.png"
        alt="RX2600 Therapeutic Robot"
        width="1600" height="900"
        fetchpriority="high"
      />
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow reveal" data-reveal>Powered by RPT</p>
      <h1 class="hero-title reveal" data-reveal>The Future<br/>of Therapy.</h1>
      <p class="hero-sub reveal" data-reveal>
        Non-surgical robotic therapy that lengthens muscle tissue,
        reduces pain, and restores mobility — session after session.
      </p>
      <div class="hero-actions reveal" data-reveal>
        <a href="#contact" class="btn-primary">Request a Demo</a>
        <a href="#product" class="btn-ghost">
          See how it works
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <div class="scroll-cue" aria-hidden="true">Scroll</div>
  </section>

  <!-- ─── STATS STRIP ─── -->
  <div class="stats-strip">
    <dl class="stats-grid">
      <div class="stat reveal" data-reveal>
        <dt class="stat-label">Muscle Tissue</dt>
        <dd class="stat-number">Lengthened</dd>
      </div>
      <div class="stat reveal" data-reveal>
        <dt class="stat-label">Pain Relief</dt>
        <dd class="stat-number">Proven</dd>
      </div>
      <div class="stat reveal" data-reveal>
        <dt class="stat-label">Mobility Gains</dt>
        <dd class="stat-number">Measurable</dd>
      </div>
      <div class="stat reveal" data-reveal>
        <dt class="stat-label">Surgical Procedures</dt>
        <dd class="stat-number">Zero</dd>
      </div>
    </dl>
  </div>

  <!-- ─── PRODUCT SECTION ─── -->
  <section class="section" id="product">
    <div class="section-inner">
      <div class="split">
        <div class="split-text">
          <p class="section-label reveal" data-reveal>The System</p>
          <h2 class="section-title reveal" data-reveal>Built to<br/>Perform.</h2>
          <p class="section-body reveal" data-reveal>
            RX2600 delivers consistent, repeatable robotic precision to
            every treatment. Where manual therapy varies, the RX2600 does not.
            Engineered for the demands of modern physical therapy clinics.
          </p>
          <a href="#contact" class="btn-primary reveal" data-reveal style="display:inline-block; margin-top: 2rem;">
            Learn More
          </a>
        </div>
        <div class="split-media reveal" data-reveal-clip data-reveal>
          <img
            src="https://rx2600.com/wp-content/uploads/2026/06/4.jpeg"
            alt="RX2600 robotic therapy system in use"
            width="800" height="600"
            loading="lazy"
          />
          <div class="split-media-overlay"></div>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ─── FULL BLEED IMAGE ─── -->
  <div class="full-bleed reveal" data-reveal aria-hidden="true">
    <img
      src="https://rx2600.com/wp-content/uploads/2025/02/Robots-and-2-therapists-scaled.jpg"
      alt="RX2600 robotic therapy with two therapists in a clinic setting"
      width="1600" height="900"
      loading="lazy"
    />
    <span class="full-bleed-caption">RX2600 — Active Clinic Environment</span>
  </div>

  <!-- ─── TECHNOLOGY ─── -->
  <section class="section" id="technology">
    <div class="section-inner">
      <p class="section-label reveal" data-reveal>Technology</p>
      <h2 class="section-title reveal" data-reveal>Precision<br/>by Design.</h2>
      <p class="section-body reveal" data-reveal>
        Robotic consistency means every patient receives the same precise
        therapeutic force — calibrated, repeatable, and clinically effective.
      </p>

      <ul class="feature-list" role="list">
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">01</p>
          <p class="feature-name">Robotic Consistency</p>
          <p class="feature-desc">Same precise therapeutic force delivered every session. No variation. No fatigue.</p>
        </li>
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">02</p>
          <p class="feature-name">Non-Surgical</p>
          <p class="feature-desc">Lengthens muscle tissue without incision, anesthesia, or recovery downtime.</p>
        </li>
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">03</p>
          <p class="feature-name">Pain Relief</p>
          <p class="feature-desc">Designed to reduce patient pain at the source through targeted tissue therapy.</p>
        </li>
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">04</p>
          <p class="feature-name">Mobility Restoration</p>
          <p class="feature-desc">Clinical outcomes that measurably increase range of motion and functional movement.</p>
        </li>
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">05</p>
          <p class="feature-name">Clinic-Ready</p>
          <p class="feature-desc">Built for high-throughput physical therapy environments. Easy integration, immediate ROI.</p>
        </li>
        <li class="feature-item reveal" data-reveal>
          <p class="feature-number">06</p>
          <p class="feature-name">Scalable System</p>
          <p class="feature-desc">Deploy in a single clinic or scale across a multi-location network with consistent results.</p>
        </li>
      </ul>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ─── CLINICAL SECTION ─── -->
  <section class="section" id="clinical">
    <div class="section-inner">
      <div class="split reverse">
        <div class="split-text">
          <p class="section-label reveal" data-reveal>Clinical Outcomes</p>
          <h2 class="section-title reveal" data-reveal>Real Results.<br/>Real Clinics.</h2>
          <p class="section-body reveal" data-reveal>
            Physical therapists and clinic operators across the country are
            using the RX2600 to deliver measurable improvements in patient
            outcomes — and stronger clinic revenue.
          </p>
          <p class="section-body reveal" data-reveal style="margin-top:1rem;">
            From pain management to mobility recovery, RX2600 becomes the
            centerpiece of a modern, advanced-care practice.
          </p>
          <a href="#contact" class="btn-primary reveal" data-reveal style="display:inline-block; margin-top:2rem;">
            See Clinic Results
          </a>
        </div>
        <div class="split-media reveal" data-reveal-clip data-reveal>
          <img
            src="https://rx2600.com/wp-content/uploads/2026/06/3.jpeg"
            alt="Therapist operating the RX2600 robot in a clinic"
            width="800" height="600"
            loading="lazy"
          />
          <div class="split-media-overlay"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOR CLINICS ─── -->
  <section class="section" id="clinics" style="background: var(--surface); border-top: 1px solid var(--border);">
    <div class="section-inner">
      <p class="section-label reveal" data-reveal>For Clinic Owners</p>
      <h2 class="section-title reveal" data-reveal style="max-width: 10ch;">
        Grow Your<br/>Practice.
      </h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; margin-top: 3rem;" class="clinics-grid">
        <div>
          <p class="section-body reveal" data-reveal>
            Adding the RX2600 to your clinic is more than upgrading equipment.
            It is adding a revenue-generating, patient-differentiating treatment
            that other clinics in your market cannot match.
          </p>
          <ul style="margin-top: 2rem; list-style: none; display: flex; flex-direction: column; gap: 1rem;">
            <li class="reveal" data-reveal style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="font-family: var(--font-display); color: var(--text-faint); font-size: 1.2rem; line-height: 1; margin-top: 2px;">→</span>
              <span style="font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6;">New revenue stream without adding staff headcount</span>
            </li>
            <li class="reveal" data-reveal style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="font-family: var(--font-display); color: var(--text-faint); font-size: 1.2rem; line-height: 1; margin-top: 2px;">→</span>
              <span style="font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6;">Advanced treatment that differentiates your practice</span>
            </li>
            <li class="reveal" data-reveal style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="font-family: var(--font-display); color: var(--text-faint); font-size: 1.2rem; line-height: 1; margin-top: 2px;">→</span>
              <span style="font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6;">Dedicated onboarding, training, and ongoing support</span>
            </li>
            <li class="reveal" data-reveal style="display: flex; gap: 1rem; align-items: flex-start;">
              <span style="font-family: var(--font-display); color: var(--text-faint); font-size: 1.2rem; line-height: 1; margin-top: 2px;">→</span>
              <span style="font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6;">Proven revenue results across existing clinic partners</span>
            </li>
          </ul>
        </div>
        <div>
          <p class="section-body reveal" data-reveal>
            Whether you are opening a new clinic or expanding an existing
            practice, the RX2600 team supports you through every step — from
            site planning and installation to patient marketing and growth.
          </p>
          <div style="display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">
            <a href="#contact" class="btn-primary reveal" data-reveal>New Clinic Inquiry</a>
            <a href="https://rx2600.com/existing-clinic/" target="_blank" rel="noopener noreferrer" class="btn-ghost reveal" data-reveal>
              Existing Clinic
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="cta-section" id="contact">
    <h2 class="cta-title reveal" data-reveal>Ready to Transform<br/>Your Clinic?</h2>
    <p class="cta-sub reveal" data-reveal>
      Join clinics already using RX2600 to deliver better outcomes and
      stronger patient satisfaction.
    </p>
    <div class="cta-actions">
      <a
        href="https://rx2600.com"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary reveal"
        data-reveal
      >Request a Demo</a>
      <a
        href="tel:8556292805"
        class="btn-ghost reveal"
        data-reveal
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.6 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.1 4.2 2 2 0 0 1 5.08 2h3a2 2 0 0 1 2 1.72c.12.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91A16 16 0 0 0 15 15.91l1.27-1.27a2 2 0 0 1 2.11-.45c.9.35 1.85.6 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
        (855) 629-2805
      </a>
    </div>
  </section>

  <!-- ─── FOOTER ─── -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-logo">RX2600</span>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://rx2600.com" target="_blank" rel="noopener noreferrer">rx2600.com</a>
        <a href="https://rx2600.com/existing-clinic/" target="_blank" rel="noopener noreferrer">Existing Clinic</a>
        <a href="https://rx2600.com/customer-service/" target="_blank" rel="noopener noreferrer">Customer Service</a>
        <a href="tel:8556292805">(855) 629-2805</a>
      </nav>
      <p class="footer-copy">© 2026 RX2600. Powered by RPT.</p>
    </div>
  </footer>

</Base>

<style>
/* Mobile clinics grid */
@media (max-width: 900px) {
  .clinics-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
}
</style>
