---
import Base from '../layouts/Base.astro';
---

<Base
  title="RX2600 — Robotic Therapy System"
  description="The RX2600 is a next-generation robotic therapy system delivering non-surgical precision treatment for pain relief and mobility restoration."
>

  <!-- ═══════════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <!-- Parallax BG -->
    <div class="hero-bg" data-parallax="0.4" aria-hidden="true">
      <img
        src="https://rx2600.com/wp-content/uploads/2024/04/robot-up-close-transparent.png"
        alt=""
        width="900"
        height="900"
        loading="eager"
        class="hero-robot-img"
      />
    </div>

    <!-- Ambient Glow -->
    <div class="hero-glow" aria-hidden="true"></div>

    <!-- Grid Lines -->
    <div class="hero-grid" aria-hidden="true"></div>

    <!-- Scan Line -->
    <div class="hero-scanline" aria-hidden="true"></div>

    <!-- Corner HUD elements -->
    <div class="hud-corner hud-tl" aria-hidden="true">
      <span class="hud-line hud-line-h"></span>
      <span class="hud-line hud-line-v"></span>
    </div>
    <div class="hud-corner hud-br" aria-hidden="true">
      <span class="hud-line hud-line-h"></span>
      <span class="hud-line hud-line-v"></span>
    </div>

    <div class="hero-content">
      <!-- Left Column -->
      <div class="hero-left">
        <p class="hero-eyebrow" data-reveal="up">
          <span class="eyebrow-bracket">[</span> System Designation RX-2600 <span class="eyebrow-bracket">]</span>
        </p>
        <h1 class="hero-title" data-text="The Machine\nThat Heals." data-reveal="up" data-delay="100">
          The Machine<br/>That Heals.
        </h1>
        <p class="hero-subtitle" data-reveal="up" data-delay="200">
          A fully autonomous robotic therapy platform engineered to deliver
          consistent, non-surgical musculoskeletal treatment — with sub-millimeter
          precision, session after session.
        </p>
        <div class="hero-cta" data-reveal="up" data-delay="300">
          <a href="#contact" class="btn-primary">Request a Demo</a>
          <a href="#product" class="btn-ghost">
            How it works
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Status Panel -->
      <aside class="hero-status" data-reveal="right" data-delay="400" aria-label="System status">
        <div class="status-header">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="status-label">SYSTEM ONLINE</span>
        </div>
        <ul class="status-list" role="list">
          <li><span class="status-key">Unit</span><span class="status-val">RX-2600 / Gen 3</span></li>
          <li><span class="status-key">Mode</span><span class="status-val">Therapy Active</span></li>
          <li><span class="status-key">Force Output</span><span class="status-val">±0.1N Precision</span></li>
          <li><span class="status-key">Protocol</span><span class="status-val">RPT™ Certified</span></li>
          <li><span class="status-key">Patients Treated</span><span class="status-val">10,000+</span></li>
        </ul>
      </aside>
    </div>

    <!-- Scroll Indicator -->
    <div class="scroll-cue" aria-hidden="true">
      <div class="scroll-line"></div>
      <span>SCROLL</span>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       STATS TICKER
  ═══════════════════════════════════════════ -->
  <div class="stats-ticker" aria-label="Key statistics">
    <div class="ticker-track">
      <div class="ticker-item">
        <span class="ticker-num" data-count="10000" data-suffix="+">0+</span>
        <span class="ticker-label">Patients Treated</span>
      </div>
      <div class="ticker-divider" aria-hidden="true">///</div>
      <div class="ticker-item">
        <span class="ticker-num" data-count="98" data-suffix="%">0%</span>
        <span class="ticker-label">Report Pain Reduction</span>
      </div>
      <div class="ticker-divider" aria-hidden="true">///</div>
      <div class="ticker-item">
        <span class="ticker-num" data-count="15" data-suffix="+ Yrs">0 Yrs</span>
        <span class="ticker-label">Research &amp; Development</span>
      </div>
      <div class="ticker-divider" aria-hidden="true">///</div>
      <div class="ticker-item">
        <span class="ticker-num" data-count="3" data-suffix="rd Gen">1st Gen</span>
        <span class="ticker-label">Robotic Platform</span>
      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════
       SECTION 01 — THE SYSTEM
  ═══════════════════════════════════════════ -->
  <section class="split-section" id="product">
    <div class="split-media" data-parallax="0.25">
      <img
        src="https://rx2600.com/wp-content/uploads/2026/06/4.jpeg"
        alt="RX2600 robotic arm performing a therapy session on a patient"
        width="800" height="900"
        loading="lazy"
      />
      <div class="media-overlay" aria-hidden="true"></div>
    </div>
    <div class="split-content">
      <p class="section-index" data-reveal="up">01 / The System</p>
      <h2 data-reveal="up" data-delay="100">Built for Precision.<br/>Built to Perform.</h2>
      <p class="body-text" data-reveal="up" data-delay="200">
        The RX2600 is not a massage chair. It is a medical-grade robotic
        therapy platform — engineered with the same precision standards as
        surgical robotics, without a single incision.
      </p>
      <p class="body-text" data-reveal="up" data-delay="250">
        Backed by over 15 years of research and development, the RX2600 uses
        Robotic Percussion Therapy (RPT™) to deliver calibrated longitudinal
        force deep into soft tissue — lengthening contracted muscles, restoring
        joint range of motion, and breaking the pain cycle at its source.
      </p>
      <a href="#technology" class="btn-primary" data-reveal="up" data-delay="300">Explore the Tech</a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       FULL BLEED CINEMATIC
  ═══════════════════════════════════════════ -->
  <div class="cinematic-block" aria-label="RX2600 robot with therapists in a clinic">
    <div class="cinematic-inner" data-parallax="0.2">
      <img
        src="https://rx2600.com/wp-content/uploads/2025/02/Robots-and-2-therapists-scaled.jpg"
        alt="RX2600 robotic therapy system with two licensed physical therapists in a modern clinic"
        width="1920" height="800"
        loading="lazy"
      />
    </div>
    <div class="cinematic-caption" aria-hidden="true">
      <span>RX2600</span> in clinical operation
    </div>
  </div>


  <!-- ═══════════════════════════════════════════
       SECTION 02 — TECHNOLOGY
  ═══════════════════════════════════════════ -->
  <section class="split-section split-reverse" id="technology">
    <div class="split-media" data-parallax="0.25">
      <img
        src="https://rx2600.com/wp-content/uploads/2024/04/robot-up-close-transparent.png"
        alt="RX2600 robotic arm head close-up showing precision engineering"
        width="800" height="900"
        loading="lazy"
        style="object-fit: contain; padding: 2rem;"
      />
      <div class="media-overlay" aria-hidden="true"></div>
    </div>
    <div class="split-content">
      <p class="section-index" data-reveal="up">02 / Technology</p>
      <h2 data-reveal="up" data-delay="100">Precision<br/>by Design.</h2>
      <p class="body-text" data-reveal="up" data-delay="150">
        Where a human therapist introduces variable force, fatigue, and
        inconsistency — the RX2600 does not. Every stroke is identical
        to the last. Every session is clinically repeatable.
      </p>

      <ul class="feature-grid" data-reveal="up" data-delay="200">
        <li class="feature-card">
          <p class="feature-num">01</p>
          <p class="feature-title">Robotic Consistency</p>
          <p class="feature-body">Sub-millimeter precision force delivered without variation or therapist fatigue.</p>
        </li>
        <li class="feature-card">
          <p class="feature-num">02</p>
          <p class="feature-title">Non-Surgical</p>
          <p class="feature-body">Deep tissue lengthening — no incision, no anesthesia, no downtime.</p>
        </li>
        <li class="feature-card">
          <p class="feature-num">03</p>
          <p class="feature-title">FDA Registered</p>
          <p class="feature-body">Cleared for clinical use — meeting federal standards for safety, efficacy, and quality.</p>
        </li>
        <li class="feature-card">
          <p class="feature-num">04</p>
          <p class="feature-title">RPT™ Protocol</p>
          <p class="feature-body">Proprietary Robotic Percussion Therapy — 15+ years of R&amp;D behind every treatment.</p>
        </li>
      </ul>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       SECTION 03 — CLINICAL OUTCOMES
  ═══════════════════════════════════════════ -->
  <section class="split-section" id="clinical">
    <div class="split-media" data-parallax="0.25">
      <img
        src="https://rx2600.com/wp-content/uploads/2026/06/3.jpeg"
        alt="Physical therapist operating the RX2600 robot on a patient in a clinic"
        width="800" height="900"
        loading="lazy"
      />
      <div class="media-overlay" aria-hidden="true"></div>
    </div>
    <div class="split-content">
      <p class="section-index" data-reveal="up">03 / Clinical Outcomes</p>
      <h2 data-reveal="up" data-delay="100">Real Results.<br/>Nationwide.</h2>
      <p class="body-text" data-reveal="up" data-delay="150">
        Across a nationwide network of physical therapy and sports medicine
        clinics, the RX2600 has become the go-to advanced therapy platform —
        delivering outcomes that manual techniques simply cannot replicate.
      </p>
      <p class="body-text" data-reveal="up" data-delay="200">
        From chronic low-back pain to post-surgical rehab, from elite athletes
        to elderly patients — the RX2600 delivers measurable mobility gains
        and lasting pain reduction across every demographic, every session.
      </p>
      <a href="#contact" class="btn-primary" data-reveal="up" data-delay="300">See Clinic Results</a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       SECTION 04 — FOR CLINIC OWNERS
  ═══════════════════════════════════════════ -->
  <section class="split-section split-reverse" id="clinics">
    <div class="split-media" data-parallax="0.25">
      <img
        src="https://rx2600.com/wp-content/uploads/2024/04/RPT-OfficePortraits-2-scaled.jpg"
        alt="RX2600 team supporting a clinic partner"
        width="800" height="900"
        loading="lazy"
      />
      <div class="media-overlay" aria-hidden="true"></div>
    </div>
    <div class="split-content">
      <p class="section-index" data-reveal="up">04 / For Clinic Owners</p>
      <h2 data-reveal="up" data-delay="100">This Is the<br/>Future of Your Clinic.</h2>
      <p class="body-text" data-reveal="up" data-delay="150">
        Imagine offering a treatment that no other clinic in your market
        has. The RX2600 is not just equipment — it is a competitive weapon
        that commands premium pricing, generates passive revenue, and keeps
        patients coming back.
      </p>
      <ul class="benefit-list" data-reveal="up" data-delay="200">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4387f" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          New premium revenue stream — no additional staff headcount required
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4387f" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Differentiate your practice across a nationwide network of leading clinics
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4387f" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          FDA registered — backed by 15+ years of clinical R&amp;D
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4387f" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          White-glove onboarding, clinical training &amp; dedicated ongoing support
        </li>
      </ul>
      <a href="#contact" class="btn-primary" data-reveal="up" data-delay="300">Claim Your Market</a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       CTA — FULL WIDTH
  ═══════════════════════════════════════════ -->
  <section class="cta-block" id="contact" aria-labelledby="cta-heading">
    <div class="cta-bg" aria-hidden="true"></div>
    <div class="cta-inner">
      <p class="cta-eyebrow" data-reveal="up">[ Ready to Deploy ]</p>
      <h2 class="cta-heading" id="cta-heading" data-reveal="up" data-delay="100">
        Transform Your Clinic.<br/>Start Now.
      </h2>
      <p class="cta-body" data-reveal="up" data-delay="200">
        Join a nationwide network of forward-thinking clinics already delivering
        the future of physical therapy — backed by 15+ years of R&amp;D and FDA registered.
      </p>
      <div class="cta-actions" data-reveal="up" data-delay="300">
        <a href="https://rx2600.com" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Request a Demo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:8556292805" class="btn-ghost">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.6 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 3.1 4.2 2 2 0 0 1 5.08 2h3a2 2 0 0 1 2 1.72c.12.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L9.09 9.91A16 16 0 0 0 15 15.91l1.27-1.27a2 2 0 0 1 2.11-.45c.9.35 1.85.6 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          (855) 629-2805
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-logo">RX2600</span>
        <span class="footer-powered">Powered by RPT™</span>
      </div>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://rx2600.com" target="_blank" rel="noopener noreferrer">rx2600.com</a>
        <a href="tel:8556292805">(855) 629-2805</a>
      </nav>
      <p class="footer-copy">© 2026 RX2600. All rights reserved.</p>
    </div>
  </footer>

</Base>

<style>
/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
.hero {
  position: relative;
  width: 100%;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  padding-top: 80px;
}

.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  pointer-events: none;
  will-change: transform;
}
.hero-robot-img {
  width: min(55vw, 700px);
  height: auto;
  object-fit: contain;
  opacity: 0.9;
  filter: drop-shadow(0 0 60px rgba(196,56,127,0.22)) drop-shadow(0 0 120px rgba(139,26,220,0.10));
  animation: robot-float 6s ease-in-out infinite;
}
@keyframes robot-float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-16px); }
}

.hero-glow {
  position: absolute;
  right: 0; top: 0;
  width: 60%; height: 100%;
  background: radial-gradient(ellipse at 70% 50%, rgba(196,56,127,0.07) 0%, rgba(139,26,220,0.04) 40%, transparent 70%);
  z-index: 1; pointer-events: none;
}

.hero-grid {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background-image:
    linear-gradient(rgba(196,56,127,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(196,56,127,0.05) 1px, transparent 1px);
  background-size: 80px 80px;
  mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.5) 0%, transparent 75%);
}

.hero-scanline {
  position: absolute; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(196,56,127,0.2), rgba(139,26,220,0.15), transparent);
  z-index: 2; pointer-events: none;
  animation: scanline 6s linear infinite;
}
@keyframes scanline {
  0%   { top: -2px; opacity: 0; }
  5%   { opacity: 1; }
  95%  { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

.hud-corner {
  position: absolute; z-index: 3; pointer-events: none;
  width: 40px; height: 40px;
}
.hud-tl { top: 96px; left: 24px; }
.hud-br { bottom: 80px; right: 24px; }
.hud-line { position: absolute; background: rgba(196,56,127,0.45); }
.hud-line-h { width: 100%; height: 1px; top: 0; left: 0; }
.hud-line-v { width: 1px; height: 100%; top: 0; left: 0; }
.hud-br .hud-line-h { top: auto; bottom: 0; }
.hud-br .hud-line-v { left: auto; right: 0; }

.hero-content {
  position: relative; z-index: 10;
  max-width: 1400px; margin: 0 auto; width: 100%;
  padding: 0 2rem 5rem;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: flex-end;
  gap: 3rem;
}

.hero-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem; letter-spacing: 3px; text-transform: uppercase;
  color: #c4387f; margin-bottom: 1.5rem;
}
.eyebrow-bracket { opacity: 0.5; }

.hero-title {
  font-size: clamp(3rem, 8vw, 6.5rem);
  font-weight: 700; line-height: 1.0;
  color: #fff;
  margin-bottom: 1.75rem;
  position: relative;
  white-space: pre-line;
}

.hero-subtitle {
  font-size: clamp(1rem, 1.5vw, 1.1rem);
  line-height: 1.8;
  color: rgba(232,232,240,0.65);
  max-width: 480px;
  margin-bottom: 2.5rem;
}

.hero-cta {
  display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;
}

.hero-status {
  background: rgba(5,5,8,0.7);
  border: 1px solid rgba(196,56,127,0.18);
  border-radius: 4px;
  padding: 1.5rem;
  backdrop-filter: blur(12px);
  min-width: 240px;
  align-self: flex-end;
}
.status-header {
  display: flex; align-items: center; gap: 0.6rem;
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(196,56,127,0.12);
}
.status-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #c4387f;
  box-shadow: 0 0 8px #c4387f;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px #c4387f; }
  50% { opacity: 0.5; box-shadow: 0 0 20px #c4387f, 0 0 40px rgba(139,26,220,0.3); }
}
.status-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem; letter-spacing: 2px;
  color: #c4387f;
}
.status-list { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
.status-list li {
  display: flex; justify-content: space-between;
  font-size: 0.72rem; gap: 1rem;
}
.status-key {
  font-family: 'Space Mono', monospace;
  color: rgba(232,232,240,0.4);
  text-transform: uppercase; letter-spacing: 1px;
}
.status-val {
  color: rgba(232,232,240,0.9);
  font-weight: 500; text-align: right;
}

.scroll-cue {
  position: absolute; bottom: 2rem; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
  z-index: 10;
}
.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, rgba(196,56,127,0.8), transparent);
  animation: scroll-drop 1.8s ease-in-out infinite;
}
@keyframes scroll-drop {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
.scroll-cue span {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem; letter-spacing: 3px;
  color: rgba(196,56,127,0.55);
}


/* ═══════════════════════════════════════════
   STATS TICKER
═══════════════════════════════════════════ */
.stats-ticker {
  background: rgba(196,56,127,0.04);
  border-top: 1px solid rgba(196,56,127,0.12);
  border-bottom: 1px solid rgba(196,56,127,0.12);
  padding: 2.5rem 2rem;
  overflow: hidden;
}
.ticker-track {
  max-width: 1400px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-around;
  flex-wrap: wrap; gap: 2rem;
}
.ticker-item {
  display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  text-align: center;
}
.ticker-num {
  font-family: 'Space Mono', monospace;
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 700;
  background: linear-gradient(135deg, #c4387f 0%, #8b22d9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
.ticker-label {
  font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
  color: rgba(232,232,240,0.45);
}
.ticker-divider {
  font-family: 'Space Mono', monospace;
  font-size: 1rem; color: rgba(196,56,127,0.25);
  letter-spacing: 2px;
}


/* ═══════════════════════════════════════════
   SPLIT SECTIONS
═══════════════════════════════════════════ */
.split-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 90vh;
  position: relative;
  overflow: hidden;
}
.split-section.split-reverse { direction: rtl; }
.split-section.split-reverse > * { direction: ltr; }

.split-media {
  position: relative; overflow: hidden;
  will-change: transform;
}
.split-media img {
  width: 100%; height: 100%;
  object-fit: cover;
  transform-origin: center;
}
.media-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, rgba(5,5,8,0.5), transparent 60%);
  z-index: 1;
}
.split-section.split-reverse .media-overlay {
  background: linear-gradient(to left, rgba(5,5,8,0.5), transparent 60%);
}

