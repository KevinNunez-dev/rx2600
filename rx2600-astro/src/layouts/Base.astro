export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'RX2600 — Robotic Therapy System',
  description = 'The RX2600 is a next-generation robotic therapy system delivering non-surgical precision treatment for pain relief and mobility restoration.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>

  <!-- Custom Cursor -->
  <div id="cursor" aria-hidden="true">
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
  </div>

  <!-- Noise Overlay -->
  <div id="noise" aria-hidden="true"></div>

  <!-- Navigation — iPhone-notch style -->
  <div class="notch-wrap" id="notch-wrap">
    <header class="header" id="header">
      <nav class="navbar">
        <div class="nav-container">
          <a href="#hero" class="logo" aria-label="RX2600 Home">
            <svg width="32" height="32" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="34" height="34" rx="4" stroke="url(#logo-grad)" stroke-width="1.5"/>
              <path d="M8 10h8c3.3 0 6 2.7 6 6s-2.7 6-6 6H8V10z" stroke="url(#logo-grad)" stroke-width="1.5" fill="none"/>
              <path d="M16 22l6 6" stroke="url(#logo-grad)" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="20" y="13" width="8" height="10" rx="1" stroke="url(#logo-grad)" stroke-width="1.5" fill="none"/>
              <defs>
                <linearGradient id="logo-grad" x1="0" y1="0" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#c4387f"/>
                  <stop offset="100%" stop-color="#8b22d9"/>
                </linearGradient>
              </defs>
            </svg>
            <span>RX2600</span>
          </a>
          <ul class="nav-links" role="list">
            <li><a href="#product" class="nav-link">System</a></li>
            <li><a href="#technology" class="nav-link">Technology</a></li>
            <li><a href="#clinical" class="nav-link">Clinical</a></li>
            <li><a href="#contact" class="nav-cta">Request Demo</a></li>
          </ul>
          <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" id="hamburger">
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>
    </header>
    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <ul role="list">
        <li><a href="#product" class="mobile-link">System</a></li>
        <li><a href="#technology" class="mobile-link">Technology</a></li>
        <li><a href="#clinical" class="mobile-link">Clinical</a></li>
        <li><a href="#contact" class="mobile-link">Request Demo</a></li>
      </ul>
    </div>
  </div>

  <main id="main-content">
    <slot />
  </main>

  <script is:inline>
    // ─── CUSTOM CURSOR ───
    (function() {
      const dot = document.getElementById('cursor-dot');
      const ring = document.getElementById('cursor-ring');
      if (!dot || !ring) return;
      let mx = -100, my = -100, rx = -100, ry = -100;
      document.addEventListener('mousemove', e => {
        mx = e.clientX; my = e.clientY;
        dot.style.transform = `translate(${mx}px, ${my}px)`;
      });
      function animateRing() {
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        ring.style.transform = `translate(${rx}px, ${ry}px)`;
        requestAnimationFrame(animateRing);
      }
      animateRing();
      document.querySelectorAll('a, button, [data-cursor-hover]').forEach(el => {
        el.addEventListener('mouseenter', () => { ring.classList.add('ring-hover'); dot.classList.add('dot-hover'); });
        el.addEventListener('mouseleave', () => { ring.classList.remove('ring-hover'); dot.classList.remove('dot-hover'); });
      });
      document.addEventListener('mouseleave', () => { dot.style.opacity='0'; ring.style.opacity='0'; });
      document.addEventListener('mouseenter', () => { dot.style.opacity='1'; ring.style.opacity='1'; });
    })();

    // ─── NOTCH SCROLL SHRINK ───
    (function() {
      const wrap = document.getElementById('notch-wrap');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 40) wrap.classList.add('notch-scrolled');
        else wrap.classList.remove('notch-scrolled');
      }, { passive: true });
    })();

    // ─── HAMBURGER ───
    (function() {
      const btn = document.getElementById('hamburger');
      const menu = document.getElementById('mobile-menu');
      if (!btn || !menu) return;
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        menu.setAttribute('aria-hidden', String(open));
        btn.classList.toggle('open', !open);
        menu.classList.toggle('open', !open);
      });
      menu.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          btn.setAttribute('aria-expanded', 'false');
          menu.setAttribute('aria-hidden', 'true');
          btn.classList.remove('open');
          menu.classList.remove('open');
        });
      });
    })();

    // ─── SCROLL REVEAL ───
    (function() {
      const reveals = document.querySelectorAll('[data-reveal]');
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
      reveals.forEach(el => io.observe(el));
    })();

    // ─── PARALLAX ───
    (function() {
      const layers = document.querySelectorAll('[data-parallax]');
      function onScroll() {
        const sy = window.scrollY;
        layers.forEach(el => {
          const speed = parseFloat(el.dataset.parallax) || 0.3;
          el.style.transform = `translateY(${sy * speed * 0.4}px) scale(1.08)`;
        });
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();

    // ─── HEADLINE SCROLL-CLIP ───
    // As the section scrolls out, the headline clips upward (like text going behind a wall)
    (function() {
      const headlines = document.querySelectorAll('.scroll-headline');
      function update() {
        const sy = window.scrollY;
        headlines.forEach(el => {
          const section = el.closest('section, .split-section');
          if (!section) return;
          const rect = section.getBoundingClientRect();
          const vh = window.innerHeight;
          // How far through the section's exit are we? 0 = just entering exit, 1 = fully gone
          const exitStart = vh * 0.3; // start clipping when 30% above viewport center
          const progress = Math.max(0, Math.min(1, -rect.top / (section.offsetHeight * 0.5)));
          const translateY = progress * -60;
          const opacity = 1 - progress * 1.4;
          el.style.transform = `translateY(${translateY}px)`;
          el.style.opacity = Math.max(0, opacity);
        });
      }
      window.addEventListener('scroll', update, { passive: true });
      update();
    })();

    // ─── COUNTER ANIMATION ───
    (function() {
      const counters = document.querySelectorAll('[data-count]');
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target;
          const target = parseInt(el.dataset.count);
          const suffix = el.dataset.suffix || '';
          const duration = 1800;
          const start = performance.now();
          function frame(now) {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(eased * target) + suffix;
            if (progress < 1) requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
          io.unobserve(el);
        });
      }, { threshold: 0.5 });
      counters.forEach(el => io.observe(el));
    })();

    // ─── SCANLINE GLITCH ───
    (function() {
      const title = document.querySelector('.hero-title');
      if (!title) return;
      setInterval(() => {
        title.classList.add('glitch');
        setTimeout(() => title.classList.remove('glitch'), 200);
      }, 4500);
    })();
  </script>
</body>
</html>

<style is:global>
  /* ─── BASE RESET ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 80px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  body {
    background: #050508;
    color: #e8e8f0;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
    cursor: none;
  }
  @media (hover: none) { body { cursor: auto; } #cursor { display: none; } }
  img, video { display: block; max-width: 100%; height: auto; }
  ul[role="list"] { list-style: none; }
  a { text-decoration: none; color: inherit; }
  button { cursor: none; background: none; border: none; }
  ::selection { background: rgba(196,56,127,0.15); color: #fff; }

  /* ─── NOISE OVERLAY ─── */
  #noise {
    position: fixed; inset: 0; z-index: 9999; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.025;
  }

  /* ─── CUSTOM CURSOR ─── */
  #cursor { position: fixed; top: 0; left: 0; z-index: 10000; pointer-events: none; }
  #cursor-dot {
    position: fixed; top: -4px; left: -4px;
    width: 8px; height: 8px;
    background: rgba(232,232,240,0.9);
    border-radius: 50%;
    transition: opacity 0.3s;
    will-change: transform;
  }
  #cursor-ring {
    position: fixed; top: -20px; left: -20px;
    width: 40px; height: 40px;
    border: 1px solid rgba(232,232,240,0.25);
    border-radius: 50%;
    transition: opacity 0.3s, width 0.3s, height 0.3s, top 0.3s, left 0.3s, border-color 0.3s;
    will-change: transform;
  }
  #cursor-ring.ring-hover {
    width: 60px; height: 60px;
    top: -30px; left: -30px;
    border-color: rgba(196,56,127,0.5);
    background: rgba(196,56,127,0.04);
  }
  #cursor-dot.dot-hover { background: #fff; }

  /* ─── NOTCH NAV ─── */
  /* Outer wrap: positions the notch pill in the top-center */
  .notch-wrap {
    position: fixed;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 900;
    /* Start wide, shrink on scroll */
    width: min(860px, 92vw);
    transition: width 0.5s cubic-bezier(0.16,1,0.3,1), top 0.5s cubic-bezier(0.16,1,0.3,1);
  }
  .notch-wrap.notch-scrolled {
    width: min(720px, 88vw);
    top: 10px;
  }

  .header {
    background: rgba(12,12,16,0.82);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 50px; /* pill notch shape */
    overflow: hidden;
    box-shadow: 0 4px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
    transition: box-shadow 0.4s;
  }
  .notch-wrap.notch-scrolled .header {
    box-shadow: 0 8px 40px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .navbar { padding: 0; }
  .nav-container {
    max-width: 100%; margin: 0; padding: 0.7rem 1.5rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .logo {
    display: flex; align-items: center; gap: 0.65rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.95rem; font-weight: 700; letter-spacing: 3px;
    color: #e8e8f0;
    transition: opacity 0.2s;
  }
  /* Only the SVG carries the gradient, text stays white — less color */
  .logo span {
    background: none;
    -webkit-text-fill-color: #e8e8f0;
    color: #e8e8f0;
  }
  .logo:hover { opacity: 0.75; }
  .nav-links {
    display: flex; list-style: none; align-items: center; gap: 2rem;
  }
  .nav-link {
    font-size: 0.75rem; letter-spacing: 1.5px; text-transform: uppercase;
    color: rgba(232,232,240,0.55);
    position: relative; padding-bottom: 2px;
    transition: color 0.25s;
  }
  .nav-link::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 1px;
    background: rgba(232,232,240,0.5);
    transition: width 0.3s;
  }
  .nav-link:hover { color: #e8e8f0; }
  .nav-link:hover::after { width: 100%; }
  .nav-cta {
    font-size: 0.7rem; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600;
    padding: 0.45rem 1.2rem;
    border: 1px solid rgba(196,56,127,0.5);
    color: #e8e8f0;
    border-radius: 50px;
    transition: background 0.3s, border-color 0.3s;
  }
  .nav-cta:hover {
    background: rgba(196,56,127,0.15);
    border-color: #c4387f;
  }
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    padding: 8px; cursor: none;
  }
  .hamburger span {
    display: block; width: 22px; height: 1px; background: rgba(232,232,240,0.7);
    transition: transform 0.3s, opacity 0.3s;
    transform-origin: center;
  }
  .hamburger.open span:first-child { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:last-child { transform: translateY(-6px) rotate(-45deg); }
  /* Mobile menu drops below the notch pill */
  .mobile-menu {
    display: none; margin-top: 8px;
    background: rgba(12,12,16,0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 20px;
    overflow: hidden;
    padding: 0.5rem 1.5rem 1.5rem;
  }
  .mobile-menu.open { display: block; }
  .mobile-link {
    display: block; padding: 0.85rem 0;
    font-size: 1rem; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(232,232,240,0.6);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.25s;
  }
  .mobile-link:hover { color: #e8e8f0; }
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .notch-wrap { width: 92vw; top: 10px; }
  }

  /* ─── SCROLL REVEAL ─── */
  [data-reveal] {
    opacity: 0;
    transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal="up"] { transform: translateY(40px); }
  [data-reveal="left"] { transform: translateX(-40px); }
  [data-reveal="right"] { transform: translateX(40px); }
  [data-reveal="scale"] { transform: scale(0.94); }
  [data-reveal].revealed { opacity: 1; transform: none; }
  [data-reveal][data-delay="100"] { transition-delay: 0.1s; }
  [data-reveal][data-delay="200"] { transition-delay: 0.2s; }
  [data-reveal][data-delay="300"] { transition-delay: 0.3s; }
  [data-reveal][data-delay="400"] { transition-delay: 0.4s; }
  [data-reveal][data-delay="500"] { transition-delay: 0.5s; }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity: 1; transform: none; transition: none; }
  }

  /* ─── SCROLL HEADLINE — exit clip ─── */
  /* Wraps h1/h2 — the JS drives translateY + opacity out as section exits */
  .scroll-headline {
    will-change: transform, opacity;
    transition: none; /* JS handles this directly for smoothness */
  }

  /* ─── BUTTONS ─── */
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    background: #c4387f;
    color: #fff;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    border: 1px solid transparent; border-radius: 2px;
    transition: box-shadow 0.3s, transform 0.2s, background 0.3s;
    position: relative;
  }
  .btn-primary:hover {
    background: #ae2e6f;
    box-shadow: 0 4px 20px rgba(196,56,127,0.3);
    transform: translateY(-1px);
  }
  .btn-primary:active { transform: translateY(0); }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    background: transparent; color: rgba(232,232,240,0.8);
    font-size: 0.72rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    border: 1px solid rgba(232,232,240,0.18); border-radius: 2px;
    transition: border-color 0.3s, color 0.3s;
  }
  .btn-ghost:hover { border-color: rgba(232,232,240,0.5); color: #fff; }

  /* ─── SCANLINE GLITCH ─── */
  @keyframes glitch-clip1 {
    0%   { clip-path: inset(40% 0 50% 0); transform: translate(-4px, 0); }
    20%  { clip-path: inset(70% 0 10% 0); transform: translate(4px, 0); }
    100% { clip-path: inset(40% 0 50% 0); transform: translate(0, 0); }
  }
  @keyframes glitch-clip2 {
    0%   { clip-path: inset(10% 0 80% 0); transform: translate(4px, 0); }
    20%  { clip-path: inset(60% 0 20% 0); transform: translate(-4px, 0); }
    100% { clip-path: inset(10% 0 80% 0); transform: translate(0, 0); }
  }
  .hero-title.glitch::before {
    content: attr(data-text); position: absolute; inset: 0;
    color: rgba(255,0,60,0.6); animation: glitch-clip1 0.2s steps(2) forwards;
  }
  .hero-title.glitch::after {
    content: attr(data-text); position: absolute; inset: 0;
    color: rgba(139,34,217,0.5); animation: glitch-clip2 0.2s steps(2) forwards;
  }
</style>
