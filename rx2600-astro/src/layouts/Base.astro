---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'RX2600 — Design Exploration',
  description = 'Advanced concepts in design with parallax scrolling effects.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="header">
    <nav class="navbar">
      <div class="nav-container">
        <div class="logo">RX2600</div>
        <button class="hamburger" aria-label="Menu">
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>
  </header>
  
  <slot />
  
  <script src="/scripts/parallax.js" is:inline></script>
  <script src="/scripts/3d-viewer.js" is:inline></script>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: #0a0a0a;
    color: #ffffff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .navbar {
    padding: 1.5rem 0;
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: #ff6b5b;
  }

  .hamburger {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px;
  }

  .hamburger span {
    width: 25px;
    height: 2px;
    background: #ffffff;
    display: block;
    transition: 0.3s;
  }

  @media (max-width: 768px) {
    .nav-container {
      padding: 0 1rem;
    }

    .logo {
      font-size: 1.2rem;
    }
  }
</style>
