---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'RX2600 — The Future of Therapy',
  description = 'The RX2600 is a next-generation robotic therapy system delivering non-surgical precision treatment for pain relief and mobility restoration.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>

  <div id="cursor" aria-hidden="true">
    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>
  </div>

  <div id="noise" aria-hidden="true"></div>

  <!-- NAV -->
  <div class="nav-outer" id="nav-outer">
    <header class="header" id="header">
      <nav class="navbar">
        <div class="nav-container">
          <a href="#" class="logo" aria-label="RX2600 Home">
            <svg width="30" height="30" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="34" height="34" rx="4" stroke="url(#lg)" stroke-width="1.5"/>
              <path d="M8 10h8c3.3 0 6 2.7 6 6s-2.7 6-6 6H8V10z" stroke="url(#lg)" stroke-width="1.5" fill="none"/>
              <path d="M16 22l6 6" stroke="url(#lg)" stroke-width="1.5" stroke-linecap="round"/>
              <rect x="20" y="13" width="8" height="10" rx="1" stroke="url(#lg)" stroke-width="1.5" fill="none"/>
              <defs>
                <linearGradient id="lg" x1="0" y1="0" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#7c3aed"/>
                  <stop offset="100%" stop-color="#4c1d95"/>
                </linearGradient>
              </defs>
            </svg>
            <span>RX2600</span>
          </a>
          <ul class="nav-links" role="list">
            <li><a href="#" data-go="1" class="nav-link">System</a></li>
            <li><a href="#" data-go="2" class="nav-link">Technology</a></li>
            <li><a href="#" data-go="3" class="nav-link">Clinical</a></li>
            <li><a href="#" data-go="5" class="nav-cta">Request Demo</a></li>
          </ul>
          <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" id="hamburger">
            <span></span><span></span>
          </button>
        </div>
      </nav>
    </header>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <ul role="list">
        <li><a href="#" data-go="1" class="mobile-link">System</a></li>
        <li><a href="#" data-go="2" class="mobile-link">Technology</a></li>
        <li><a href="#" data-go="3" class="mobile-link">Clinical</a></li>
        <li><a href="#" data-go="5" class="mobile-link">Request Demo</a></li>
      </ul>
    </div>
  </div>

  <!-- Section progress dots -->
  <nav class="section-dots" id="section-dots" aria-label="Section navigation">
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <script is:inline>
  (function() {
    /* ─── CURSOR ─── */
    const dot = document.getElementById('cursor-dot');
    const ring = document.getElementById('cursor-ring');
    if (dot && ring) {
      let mx=-100,my=-100,rx=-100,ry=-100;
      document.addEventListener('mousemove', e => {
        mx=e.clientX; my=e.clientY;
        dot.style.transform=`translate(${mx}px,${my}px)`;
      });
      (function loop(){ rx+=(mx-rx)*0.12; ry+=(my-ry)*0.12; ring.style.transform=`translate(${rx}px,${ry}px)`; requestAnimationFrame(loop); })();
      document.querySelectorAll('a,button,[data-cursor-hover]').forEach(el=>{
        el.addEventListener('mouseenter',()=>{ring.classList.add('ring-hover');dot.classList.add('dot-hover');});
        el.addEventListener('mouseleave',()=>{ring.classList.remove('ring-hover');dot.classList.remove('dot-hover');});
      });
      document.addEventListener('mouseleave',()=>{dot.style.opacity='0';ring.style.opacity='0';});
      document.addEventListener('mouseenter',()=>{dot.style.opacity='1';ring.style.opacity='1';});
    }

    /* ─── HAMBURGER ─── */
    const btn=document.getElementById('hamburger');
    const mnu=document.getElementById('mobile-menu');
    if(btn&&mnu){
      btn.addEventListener('click',()=>{
        const o=btn.getAttribute('aria-expanded')==='true';
        btn.setAttribute('aria-expanded',String(!o));
        mnu.setAttribute('aria-hidden',String(o));
        btn.classList.toggle('open',!o);
        mnu.classList.toggle('open',!o);
      });
    }

    /* ─── COUNTER ANIMATION ─── */
    const counters=document.querySelectorAll('[data-count]');
    if(counters.length){
      const cio=new IntersectionObserver(entries=>{
        entries.forEach(e=>{
          if(!e.isIntersecting)return;
          const el=e.target,target=parseInt(el.dataset.count),suffix=el.dataset.suffix||'';
          const dur=1800,start=performance.now();
          function frame(now){
            const p=Math.min((now-start)/dur,1),eased=1-Math.pow(1-p,3);
            el.textContent=Math.floor(eased*target)+suffix;
            if(p<1)requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
          cio.unobserve(el);
        });
      },{threshold:0.5});
      counters.forEach(el=>cio.observe(el));
    }

    /* ─── SCANLINE GLITCH ─── */
    const htitle=document.querySelector('.hero-title');
    if(htitle){
      setInterval(()=>{
        htitle.classList.add('glitch');
        setTimeout(()=>htitle.classList.remove('glitch'),200);
      },4500);
    }

    /* ═══════════════════════════════════════════════════
       FULLSCREEN SCROLL ENGINE
       - Each [data-panel] = 100vh, stacked absolutely
       - Mouse wheel / touch drives a custom scroll value
       - rAF lerps toward target, updates transforms
       - Exit: darkens + slides left or right
       - Enter: rises from slight translateY below
    ═══════════════════════════════════════════════════ */
    const panels = Array.from(document.querySelectorAll('[data-panel]'));
    if (!panels.length) return;

    const LERP = 0.072;          // smoothing factor (lower = silkier)
    const SLIDE_PX = 120;        // how far panels slide on exit (px)
    let current = 0;
    let target = 0;
    let scrollY = 0;
    let rafId = null;
    let isAnimating = false;
    let lastWheelTime = 0;
    const VH = window.innerHeight;
    const total = panels.length;

    // Make main a scroll container (height = panels * vh)
    const main = document.getElementById('main-content');
    if (main) main.style.height = (total * 100) + 'vh';

    // Position panels
    panels.forEach((p, i) => {
      p.style.cssText = `
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100vh;
        will-change: transform, opacity;
        z-index: ${10 + (total - i)};
        overflow: hidden;
      `;
    });

    // Build progress dots
    const dotsNav = document.getElementById('section-dots');
    if (dotsNav) {
      panels.forEach((p, i) => {
        const d = document.createElement('button');
        d.className = 'sdot' + (i === 0 ? ' sdot-active' : '');
        d.setAttribute('aria-label', 'Go to section ' + (i + 1));
        d.dataset.goto = i;
        d.addEventListener('click', () => goTo(i));
        dotsNav.appendChild(d);
      });
    }

    function setDots(idx) {
      if (!dotsNav) return;
      dotsNav.querySelectorAll('.sdot').forEach((d, i) => {
        d.classList.toggle('sdot-active', i === idx);
      });
    }

    // NAV collapse on non-zero panel
    const navOuter = document.getElementById('nav-outer');
    function updateNav(idx) {
      if (!navOuter) return;
      if (idx > 0) navOuter.classList.add('nav-collapsed');
      else navOuter.classList.remove('nav-collapsed');
    }

    // Nav data-go links
    document.querySelectorAll('[data-go]').forEach(el => {
      el.addEventListener('click', e => {
        e.preventDefault();
        goTo(parseInt(el.dataset.go));
        if (mnu) { mnu.classList.remove('open'); mnu.setAttribute('aria-hidden','true'); }
        if (btn) { btn.classList.remove('open'); btn.setAttribute('aria-expanded','false'); }
      });
    });

    function goTo(idx) {
      idx = Math.max(0, Math.min(total - 1, idx));
      current = idx;
      target = idx;
      scrollY = idx;
      applyPanels(idx);
      setDots(idx);
      updateNav(idx);
      // re-trigger reveals on target panel
      triggerReveals(panels[idx]);
    }

    function applyPanels(progress) {
      // progress is float: e.g. 1.4 means 40% through transition from 1→2
      panels.forEach((p, i) => {
        const diff = progress - i;
        let tx = 0, ty = 0, opacity = 1, scale = 1;

        if (diff < -0.001) {
          // Panel is BELOW current (upcoming): rise from below slightly
          ty = Math.min(60, -diff * 60);
          opacity = Math.max(0, 1 + diff * 2);
          if (diff < -0.5) { opacity = 0; ty = 60; }
        } else if (diff > 0.001) {
          // Panel is ABOVE current (exiting): slide left + darken
          const exit = Math.min(1, diff);
          // Alternate: odd panels slide left, even panels slide right
          const dir = i % 2 === 0 ? -1 : 1;
          tx = exit * SLIDE_PX * dir;
          opacity = Math.max(0, 1 - exit * 1.8);
          scale = 1 - exit * 0.04;
          if (exit >= 1) { opacity = 0; }
        }

        p.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
        p.style.opacity = opacity;
        // Only the current+adjacent panels need to be visible in z-stack
        p.style.pointerEvents = (Math.abs(diff) < 0.5) ? 'auto' : 'none';
      });
    }

    // Smooth scroll value
    let smoothScroll = 0;

    function tick() {
      smoothScroll += (target - smoothScroll) * LERP;
      // Snap when close enough
      if (Math.abs(smoothScroll - target) < 0.001) smoothScroll = target;
      applyPanels(smoothScroll);
      rafId = requestAnimationFrame(tick);
    }
    rafId = requestAnimationFrame(tick);

    // Wheel handler
    function onWheel(e) {
      e.preventDefault();
      const now = Date.now();
      if (now - lastWheelTime < 80) return; // throttle
      lastWheelTime = now;
      const dir = e.deltaY > 0 ? 1 : -1;
      const next = Math.max(0, Math.min(total - 1, target + dir));
      if (next !== target) {
        target = next;
        current = next;
        setDots(next);
        updateNav(next);
        triggerReveals(panels[next]);
      }
    }
    window.addEventListener('wheel', onWheel, { passive: false });

    // Touch handler
    let touchStartY = 0;
    window.addEventListener('touchstart', e => { touchStartY = e.touches[0].clientY; }, { passive: true });
    window.addEventListener('touchend', e => {
      const dy = touchStartY - e.changedTouches[0].clientY;
      if (Math.abs(dy) < 40) return;
      const dir = dy > 0 ? 1 : -1;
      const next = Math.max(0, Math.min(total - 1, target + dir));
      if (next !== target) {
        target = next;
        current = next;
        setDots(next);
        updateNav(next);
        triggerReveals(panels[next]);
      }
    }, { passive: true });

    // Keyboard arrows
    window.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        e.preventDefault();
        const next = Math.min(total - 1, target + 1);
        if (next !== target) { target = next; current = next; setDots(next); updateNav(next); triggerReveals(panels[next]); }
      }
      if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        e.preventDefault();
        const next = Math.max(0, target - 1);
        if (next !== target) { target = next; current = next; setDots(next); updateNav(next); triggerReveals(panels[next]); }
      }
    });

    // Scroll reveal — trigger per panel when it becomes active
    function triggerReveals(panel) {
      if (!panel) return;
      panel.querySelectorAll('[data-reveal]').forEach(el => {
        el.classList.remove('revealed');
        // Small stagger so they fire in sequence
        const delay = parseInt(el.dataset.delay || 0);
        setTimeout(() => el.classList.add('revealed'), delay + 80);
      });
    }
    // Trigger first panel on load
    setTimeout(() => triggerReveals(panels[0]), 200);

    // Initial paint
    applyPanels(0);
    setDots(0);
    updateNav(0);

  })();
  </script>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow: hidden; /* the engine controls scrolling */
  }
  body {
    background: #000;
    color: #e8e8f0;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    line-height: 1.6;
    overflow: hidden;
    cursor: none;
    height: 100vh;
  }
  @media (hover: none) { body { cursor: auto; } #cursor { display: none; } }
  img, video { display: block; max-width: 100%; height: auto; }
  ul[role="list"] { list-style: none; }
  a { text-decoration: none; color: inherit; }
  button { background: none; border: none; cursor: none; }
  ::selection { background: rgba(124,58,237,0.2); color: #fff; }

  #noise {
    position: fixed; inset: 0; z-index: 9999; pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.025;
  }

  #cursor { position: fixed; top:0; left:0; z-index:10000; pointer-events:none; }
  #cursor-dot {
    position: fixed; top:-4px; left:-4px; width:8px; height:8px;
    background: rgba(232,232,240,0.9); border-radius:50%;
    transition: opacity 0.3s; will-change: transform;
  }
  #cursor-ring {
    position: fixed; top:-20px; left:-20px; width:40px; height:40px;
    border: 1px solid rgba(232,232,240,0.2); border-radius:50%;
    transition: opacity 0.3s, width 0.3s, height 0.3s, top 0.3s, left 0.3s, border-color 0.3s;
    will-change: transform;
  }
  #cursor-ring.ring-hover { width:60px; height:60px; top:-30px; left:-30px; border-color:rgba(124,58,237,0.5); background:rgba(124,58,237,0.04); }
  #cursor-dot.dot-hover { background:#fff; }

  /* ── NAV ── */
  .nav-outer {
    position: fixed; top:16px; left:0; right:0; z-index:900; padding:0 2rem;
    transition: left .6s cubic-bezier(.16,1,.3,1), right .6s cubic-bezier(.16,1,.3,1), top .5s cubic-bezier(.16,1,.3,1), padding .6s cubic-bezier(.16,1,.3,1);
  }
  .header {
    background: transparent; border:1px solid transparent; border-radius:50px; overflow:hidden; box-shadow:none;
    transition: background .5s cubic-bezier(.16,1,.3,1), border-color .5s, box-shadow .5s, border-radius .5s;
  }
  .nav-outer.nav-collapsed {
    left:50%; right:auto; width:min(780px,88vw);
    transform:translateX(-50%); padding:0; top:12px;
  }
  .nav-outer.nav-collapsed .header {
    background: rgba(5,5,8,.9);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border-color: rgba(255,255,255,.07);
    box-shadow: 0 4px 32px rgba(0,0,0,.7), inset 0 1px 0 rgba(255,255,255,.05);
  }
  .navbar { padding:0; }
  .nav-container { max-width:100%; margin:0; padding:.75rem 1.5rem; display:flex; justify-content:space-between; align-items:center; }
  .nav-outer:not(.nav-collapsed) .nav-container { padding:.75rem .5rem; }
  .logo { display:flex; align-items:center; gap:.65rem; font-family:'Space Mono',monospace; font-size:.95rem; font-weight:700; letter-spacing:3px; color:#e8e8f0; transition:opacity .2s; }
  .logo span { color:#e8e8f0; }
  .logo:hover { opacity:.7; }
  .nav-links { display:flex; list-style:none; align-items:center; gap:2rem; }
  .nav-link { font-size:.75rem; letter-spacing:1.5px; text-transform:uppercase; color:rgba(232,232,240,.5); position:relative; padding-bottom:2px; transition:color .25s; }
  .nav-link::after { content:''; position:absolute; bottom:0; left:0; width:0; height:1px; background:rgba(232,232,240,.4); transition:width .3s; }
  .nav-link:hover { color:#e8e8f0; }
  .nav-link:hover::after { width:100%; }
  .nav-cta { font-size:.7rem; letter-spacing:1.5px; text-transform:uppercase; font-weight:600; padding:.45rem 1.2rem; border:1px solid rgba(124,58,237,.45); color:#e8e8f0; border-radius:50px; transition:background .3s, border-color .3s; }
  .nav-cta:hover { background:rgba(124,58,237,.15); border-color:#7c3aed; }
  .hamburger { display:none; flex-direction:column; gap:5px; padding:8px; }
  .hamburger span { display:block; width:22px; height:1px; background:rgba(232,232,240,.7); transition:transform .3s, opacity .3s; transform-origin:center; }
  .hamburger.open span:first-child { transform:translateY(6px) rotate(45deg); }
  .hamburger.open span:last-child { transform:translateY(-6px) rotate(-45deg); }
  .mobile-menu { display:none; margin-top:8px; background:rgba(0,0,0,.97); backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,.06); border-radius:20px; overflow:hidden; padding:.5rem 1.5rem 1.5rem; }
  .mobile-menu.open { display:block; }
  .mobile-link { display:block; padding:.85rem 0; font-size:1rem; letter-spacing:2px; text-transform:uppercase; color:rgba(232,232,240,.55); border-bottom:1px solid rgba(255,255,255,.04); transition:color .25s; }
  .mobile-link:hover { color:#e8e8f0; }
  @media (max-width:768px) {
    .nav-links { display:none; }
    .hamburger { display:flex; }
    .nav-outer { left:0; right:0; padding:0 1rem; top:10px; }
    .nav-outer.nav-collapsed { width:94vw; }
  }

  /* ── SECTION DOTS ── */
  .section-dots {
    position: fixed;
    right: 1.75rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 800;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: center;
  }
  .sdot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    border: none;
    padding: 0;
    cursor: none;
    transition: background 0.3s, transform 0.3s, height 0.3s;
  }
  .sdot-active {
    background: rgba(255,255,255,0.75);
    height: 20px;
    border-radius: 3px;
    transform: scaleX(1);
  }
  @media (max-width: 768px) { .section-dots { right: 0.75rem; } }

  /* ── SCROLL REVEAL ── */
  [data-reveal] { opacity:0; transition:opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
  [data-reveal="up"] { transform:translateY(40px); }
  [data-reveal="left"] { transform:translateX(-40px); }
  [data-reveal="right"] { transform:translateX(40px); }
  [data-reveal="scale"] { transform:scale(.94); }
  [data-reveal].revealed { opacity:1; transform:none; }
  [data-reveal][data-delay="100"] { transition-delay:.1s; }
  [data-reveal][data-delay="200"] { transition-delay:.2s; }
  [data-reveal][data-delay="300"] { transition-delay:.3s; }
  [data-reveal][data-delay="400"] { transition-delay:.4s; }
  [data-reveal][data-delay="500"] { transition-delay:.5s; }
  @media (prefers-reduced-motion:reduce) { [data-reveal] { opacity:1; transform:none; transition:none; } }

  /* ── BUTTONS ── */
  .btn-primary {
    display:inline-flex; align-items:center; gap:.5rem;
    padding:.85rem 1.8rem;
    background:#6b21e8; color:#fff;
    font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase;
    border:1px solid transparent; border-radius:2px;
    transition:box-shadow .3s, transform .2s, background .3s;
    position:relative;
  }
  .btn-primary:hover { background:#5b17cc; box-shadow:0 4px 24px rgba(107,33,232,.35); transform:translateY(-1px); }
  .btn-primary:active { transform:translateY(0); }
  .btn-ghost {
    display:inline-flex; align-items:center; gap:.5rem;
    padding:.85rem 1.8rem;
    background:transparent; color:rgba(232,232,240,.8);
    font-size:.72rem; font-weight:600; letter-spacing:2px; text-transform:uppercase;
    border:1px solid rgba(232,232,240,.15); border-radius:2px;
    transition:border-color .3s, color .3s;
  }
  .btn-ghost:hover { border-color:rgba(232,232,240,.45); color:#fff; }

  /* ── GLITCH ── */
  @keyframes glitch-clip1 {
    0%   { clip-path:inset(40% 0 50% 0); transform:translate(-4px,0); }
    20%  { clip-path:inset(70% 0 10% 0); transform:translate(4px,0); }
    100% { clip-path:inset(40% 0 50% 0); transform:translate(0,0); }
  }
  @keyframes glitch-clip2 {
    0%   { clip-path:inset(10% 0 80% 0); transform:translate(4px,0); }
    20%  { clip-path:inset(60% 0 20% 0); transform:translate(-4px,0); }
    100% { clip-path:inset(10% 0 80% 0); transform:translate(0,0); }
  }
  .hero-title.glitch::before { content:attr(data-text); position:absolute; inset:0; color:rgba(255,0,60,.5); animation:glitch-clip1 .2s steps(2) forwards; }
  .hero-title.glitch::after  { content:attr(data-text); position:absolute; inset:0; color:rgba(107,33,232,.5); animation:glitch-clip2 .2s steps(2) forwards; }
</style>
